# Скопируй в backend/.env. .env в репозиторий не коммитим (см. .gitignore).
# Проект открытый: реальные секреты/домены сюда НЕ вписывать — это только образец.
# Значения ниже — для ЛОКАЛЬНОГО запуска; прод-отличия помечены комментариями.

# Прод: сгенерировать python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-dev-only-key-change-me
# Прод: 0
DJANGO_DEBUG=1
# Прод: домены сайта через запятую, напр. site.example,www.site.example
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Прод (нужно для входа в /admin/ по https): со схемой, напр.
#   https://site.example,https://www.site.example
DJANGO_CSRF_TRUSTED_ORIGINS=

DB_NAME=plume
DB_USER=plume
DB_PASSWORD=plume
# Прод: localhost / 3306. Локально (Docker): 127.0.0.1 / 3307.
DB_HOST=127.0.0.1
DB_PORT=3307

# Прод: фронт с того же origin — можно оставить пустым.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
