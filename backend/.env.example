# Скопируй в backend/.env для локального запуска. .env в репозиторий не коммитим.
DJANGO_SECRET_KEY=django-insecure-dev-only-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=plume
DB_USER=plume
DB_PASSWORD=plume
DB_HOST=127.0.0.1
DB_PORT=3307

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
